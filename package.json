{
  "name": "manager-niox-js",
  "version": "1.0.0",
  "description": "Discord bot manager for selling, licensing, provisioning, and renewing hosted bots.",
  "main": "src/index.js",
  "scripts": {
    "ci": "npm run validate && npm run smoke && npm run check:templates && npm run security:scan",
    "dev": "cross-env NODE_ENV=development node --watch src/index.js",
    "start": "cross-env NODE_ENV=production node src/index.js",
    "validate": "node scripts/validate.js",
    "smoke": "node scripts/smoke.js",
    "check:templates": "node scripts/check-templates.js",
    "security:scan": "node scripts/scan-secrets.js",
    "test": "npm run validate && npm run smoke"
  },
  "keywords": [
    "discord",
    "bot-manager",
    "discord-js",
    "licensing",
    "saas",
    "checkout",
    "mongodb"
  ],
  "author": "Manager Niox contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@camposcloud/sdk": "^1.1.3",
    "@squarecloud/api": "^3.8.0",
    "@discordjs/voice": "^0.19.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.4",
    "bytes": "^3.1.2",
    "canvas": "^3.1.2",
    "chart.js": "^4.5.0",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "discord.js": "^14.15.3",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "fast-discord-js": "^1.1.0",
    "ignore": "^7.0.5",
    "mongoose": "^8.7.0",
    "module-alias": "^2.2.3",
    "multer": "^2.0.2",
    "qrcode": "^1.5.4",
    "qrcode-pix": "^5.0.0",
    "sdk-node-apis-efi": "^1.2.25",
    "semver": "^7.7.2",
    "wio.db": "^4.0.22"
  },
  "_moduleAliases": {
    "@root": "."
  }
}
