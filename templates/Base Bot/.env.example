DISCORD_TOKEN=
BOT_PREFIX=!

# Use true em producao para registrar slash commands globais.
GLOBAL_COMMANDS=false

# Opcional em desenvolvimento: separe IDs por virgula para registrar comandos rapido.
GUILD_IDS=

# O Base Bot le as licencas emitidas pelo manager nessa database.
MANAGER_BRIDGE_MONGO_URI=mongodb://127.0.0.1:27017
MANAGER_BRIDGE_DB_NAME=manager_bridge

# Alias tambem aceitos:
# LICENSE_BRIDGE_MONGO_URI=
# MONGO_DB_URL=
# MONGO_URI=

# So habilite se quiser que o bot tente criar indices no manager_bridge.
AUTO_ENSURE_BRIDGE_INDEXES=false

# Avatar de bot no Discord e global. Deixe false para nao mudar todos os servidores.
APPLY_LICENSE_AVATAR=false
