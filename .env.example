NODE_ENV=development

# Discord bot that runs the manager.
BOT_TOKEN=
OWNER_ID=

# MongoDB
MONGO_DB_URL=
MANAGER_CORE_DB_NAME=manager_core
MANAGER_BRIDGE_DB_NAME=manager_bridge
MANAGER_BRIDGE_MONGO_URI=

# HTTP server / checkout
PORT=3000
HTTP_PORT=
CHECKOUT_ALLOWED_ORIGINS=

# Shared bot delivery
SHARED_BOT_CLIENT_ID=
SHARED_BOT_TOKEN=
SHARED_BOT_INVITE_PERMISSIONS=8
SHARED_BOT_SOURCE_DIR=

# Private bot delivery
MANAGED_SERVICE_SOURCE_PATH=
DEDICATED_BOT_MONGO_URI=
LICENSE_BRIDGE_MONGO_URI=

# Charts and diagnostics
CHART_FONT_FAMILY=sans-serif

# Optional Mercado Pago override for local testing.
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
